# ── Required ──────────────────────────────────────────────────────────────────

# PostgreSQL connection string.
# On Vercel use a pooled URL (Neon, Supabase pooler, or Vercel Postgres).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/freelance_platform"

# NextAuth secret — generate with: openssl rand -base64 32
# On Vercel: Project → Settings → Environment Variables → Production (+ Preview).
# Legacy name NEXTAUTH_SECRET is also accepted if AUTH_SECRET is unset.
AUTH_SECRET="change-me-to-a-random-secret"

# Public site URL (no trailing slash). Required in production for SEO, emails, Stripe redirects.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ── Optional: Vercel Blob (avatars & portfolio uploads) ───────────────────────

# Created automatically when you add a Blob store in Vercel → Storage.
# Local dev: copy from Vercel or leave unset to save files under public/uploads/.
# BLOB_READ_WRITE_TOKEN=""

# ── Optional: Google OAuth ────────────────────────────────────────────────────

# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# ── Optional: Stripe ────────────────────────────────────────────────────────

# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""
# STRIPE_PRICE_PRO_FREELANCER=""
# STRIPE_PRICE_FEATURE_PROJECT=""
# STRIPE_PRICE_FEATURE_PROFILE=""

# ── Optional: Email (Resend) ─────────────────────────────────────────────────

# RESEND_API_KEY=""
# EMAIL_FROM="Taskery <noreply@taskery.com>"

# ── Local dev only ───────────────────────────────────────────────────────────

# Cloudflare tunnel hostname (npm run tunnel). Do not set in production.
# TUNNEL_HOST="xxxx.trycloudflare.com"

# LAN IP for testing from phone on same Wi-Fi (allowedDevOrigins). Optional.
# DEV_LAN_HOST="192.168.1.27"
