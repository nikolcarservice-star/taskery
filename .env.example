# ── Required ──────────────────────────────────────────────────────────────────

# PostgreSQL connection string.
# On Vercel use a pooled URL (Neon, Supabase pooler, or Vercel Postgres).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/freelance_platform"

# NextAuth secret — generate with: openssl rand -base64 32
# On Vercel: Project → Settings → Environment Variables → Production (+ Preview).
# Legacy name NEXTAUTH_SECRET is also accepted if AUTH_SECRET is unset.
AUTH_SECRET="change-me-to-a-random-secret"

# Public site URL (no trailing slash). Required in production for SEO, emails, Stripe redirects.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ── Optional: Platform ───────────────────────────────────────────────────────

# Set to "false" to publish new client projects immediately (skip admin pre-moderation).
# PROJECT_PRE_MODERATION="false"

# Set to "false" to publish portfolio items and avatars without admin review.
# CONTENT_PRE_MODERATION="false"

# ── Optional: Vercel Blob (avatars & portfolio uploads) ───────────────────────

# Created automatically when you add a Blob store in Vercel → Storage.
# Required on Vercel (filesystem is read-only). Local dev: leave unset to use public/uploads/.
# BLOB_READ_WRITE_TOKEN=""

# ── Optional: Google OAuth ────────────────────────────────────────────────────

# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# ── Optional: Stripe ────────────────────────────────────────────────────────

# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""
# STRIPE_PRICE_PRO_FREELANCER=""
# STRIPE_PRICE_FEATURE_PROJECT=""
# STRIPE_PRICE_FEATURE_PROFILE=""
# Set to "true" to enable Stripe Connect onboarding and auto-payouts on withdrawal approval.
# STRIPE_CONNECT_ENABLED="true"

# ── Optional: Push notifications (Web Push / VAPID) ───────────────────────────

# Generate keys: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=""
# VAPID_PRIVATE_KEY=""
# VAPID_SUBJECT="mailto:admin@taskery.com"

# ── Optional: Telegram bot ────────────────────────────────────────────────────

# TELEGRAM_BOT_TOKEN=""
# TELEGRAM_BOT_USERNAME="TaskeryBot"
# TELEGRAM_WEBHOOK_SECRET=""

# ── Optional: Email (Resend) ─────────────────────────────────────────────────

# RESEND_API_KEY=""
# EMAIL_FROM="Taskery <noreply@taskery.com>"

# ── Production deploy checklist ────────────────────────────────────────────────
#
# After pulling new code with schema changes:
#   npx prisma db push
#
# Recommended production env (besides required vars above):
#   RESEND_API_KEY + EMAIL_FROM          — transactional email
#   BLOB_READ_WRITE_TOKEN                — avatar/portfolio uploads on Vercel
#   STRIPE_SECRET_KEY + STRIPE_WEBHOOK_SECRET — payments & escrow
#   VAPID_PUBLIC_KEY + VAPID_PRIVATE_KEY — browser push notifications
#   TELEGRAM_BOT_TOKEN + TELEGRAM_BOT_USERNAME — Telegram bot linking
#
# Verify NEXT_PUBLIC_SITE_URL matches your production domain (no trailing slash).

# ── Local dev only ───────────────────────────────────────────────────────────

# Cloudflare tunnel hostname (npm run tunnel). Do not set in production.
# TUNNEL_HOST="xxxx.trycloudflare.com"

# LAN IP for testing from phone on same Wi-Fi (allowedDevOrigins). Optional.
# DEV_LAN_HOST="192.168.1.27"
