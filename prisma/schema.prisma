// Taskery — production schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  FREELANCER
  CLIENT
  ADMIN
}

enum AdminPermission {
  FULL_ACCESS
  STAFF_MANAGE
  MODERATION
  USERS
  FINANCE
}

enum SubscriptionPlan {
  FREE
  PRO
}

enum ProjectStatus {
  OPEN
  IN_PROGRESS
  CLOSED
  UNDER_DISPUTE
}

enum BidStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum ContractStatus {
  AWAITING_FUNDING
  ESCROWED
  RELEASED
  REFUNDED
}

enum PaymentType {
  BALANCE_TOPUP
  SUBSCRIPTION
  FEATURE_PROJECT
  FEATURE_PROFILE
  COMMISSION
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum LanguageLevel {
  NATIVE
  ADVANCED
  INTERMEDIATE
  BASIC
}

enum WorkAvailability {
  AVAILABLE
  SLIGHTLY_BUSY
  VERY_BUSY
  NOT_WORKING
  ON_VACATION
}

enum LegalStatus {
  INDIVIDUAL
  SELF_EMPLOYED
  COMPANY
}

enum NotificationType {
  PROJECT_MATCH
  BID_ACCEPTED
  BID_MESSAGE
  NEW_MESSAGE
  NEW_BID
}

enum ReportTargetType {
  USER
  PROJECT
}

enum ReportReason {
  UNDERPRICED
  SPAM
  FRAUD
  HARASSMENT
  IRRELEVANT
  POLICY_VIOLATION
  FAKE_PROFILE
  OTHER
}

enum ReportStatus {
  PENDING
  IN_REVIEW
  RESOLVED
  DISMISSED
}

enum MessageKind {
  USER
  EXTERNAL_CONTACT_WARNING
  DISPUTE_OPENED
  DISPUTE_ADMIN_NOTE
}

model User {
  id                 String           @id @default(cuid())
  email              String           @unique
  passwordHash       String?          @map("password_hash")
  role               Role
  name               String?
  firstName          String?          @map("first_name")
  lastName           String?          @map("last_name")
  avatar             String?
  bio                String?          @db.Text
  phone              String?
  country            String?
  city               String?
  dateOfBirth        DateTime?        @map("date_of_birth") @db.Date
  rating             Float            @default(0)
  balance            Decimal          @default(0) @db.Decimal(12, 2)
  subscriptionPlan   SubscriptionPlan @default(FREE) @map("subscription_plan")
  stripeCustomerId   String?          @unique @map("stripe_customer_id")
  featuredUntil      DateTime?        @map("featured_until")
  adminPermissions   AdminPermission[] @default([]) @map("admin_permissions")
  adminActive        Boolean          @default(true) @map("admin_active")
  interfaceLanguage  String           @default("ru") @map("interface_language")
  autoTranslate      Boolean          @default(true) @map("auto_translate")
  bannedAt           DateTime?        @map("banned_at")
  banReason          String?          @map("ban_reason") @db.Text
  deletedAt          DateTime?        @map("deleted_at")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  freelancerProfile       FreelancerProfile?
  projectsAsClient        Project[]          @relation("ClientProjects")
  bids                    Bid[]
  contractsAsClient       Contract[]         @relation("ClientContracts")
  contractsAsFreelancer   Contract[]         @relation("FreelancerContracts")
  reviewsGiven            Review[]           @relation("ReviewsGiven")
  reviewsReceived         Review[]           @relation("ReviewsReceived")
  conversationsAsClient   Conversation[]     @relation("ClientConversations")
  conversationsAsFreelancer Conversation[]   @relation("FreelancerConversations")
  messagesSent            Message[]          @relation("MessagesSent")
  bidMessagesSent         BidMessage[]       @relation("BidMessagesSent")
  messageViolations       Message[]          @relation("MessageViolations")
  bidMessageViolations    BidMessage[]       @relation("BidMessageViolations")
  payments                Payment[]
  passwordResetTokens     PasswordResetToken[]
  languages               UserLanguage[]
  settings                UserSettings?
  notifications           Notification[]
  reportsFiled            Report[]           @relation("ReportsFiled")
  reportsAgainst          Report[]           @relation("ReportsAgainstUser")
  reportsResolved         Report[]           @relation("ReportsResolved")
  contactWarningDismissals AdminContactWarningDismissal[]

  @@map("users")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String
  body      String?          @db.Text
  link      String?
  metadata  Json?
  readAt    DateTime?        @map("read_at")
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@map("notifications")
}

model FreelancerProfile {
  id                     String            @id @default(cuid())
  userId                 String            @unique @map("user_id")
  title                  String?
  hourlyRate             Decimal?          @map("hourly_rate") @db.Decimal(10, 2)
  wantsFreelanceProjects Boolean           @default(true) @map("wants_freelance_projects")
  wantsRemoteWork        Boolean           @default(false) @map("wants_remote_work")
  workAvailability       WorkAvailability  @default(AVAILABLE) @map("work_availability")
  legalStatus            LegalStatus?      @map("legal_status")
  taxId                  String?           @map("tax_id")
  website                String?
  experienceYears        Int?              @map("experience_years")
  portfolioBoostGranted  Boolean           @default(false) @map("portfolio_boost_granted")
  createdAt              DateTime          @default(now()) @map("created_at")
  updatedAt              DateTime          @updatedAt @map("updated_at")

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills         Skill[]         @relation("FreelancerSkills")
  portfolioItems PortfolioItem[]

  @@map("freelancer_profiles")
}

model PortfolioItem {
  id                  String   @id @default(cuid())
  freelancerProfileId String   @map("freelancer_profile_id")
  title               String
  description         String?  @db.Text
  imageUrl            String?  @map("image_url")
  projectUrl          String?  @map("project_url")
  createdAt           DateTime @default(now()) @map("created_at")

  freelancerProfile FreelancerProfile @relation(fields: [freelancerProfileId], references: [id], onDelete: Cascade)

  @@map("portfolio_items")
}

model UserLanguage {
  id       String        @id @default(cuid())
  userId   String        @map("user_id")
  language String
  level    LanguageLevel
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, language])
  @@map("user_languages")
}

model UserSettings {
  id                    String   @id @default(cuid())
  userId                String   @unique @map("user_id")
  emailProjectDigest    Boolean  @default(true) @map("email_project_digest")
  emailNewMessages      Boolean  @default(true) @map("email_new_messages")
  emailServiceInfo      Boolean  @default(true) @map("email_service_info")
  emailPromotions       Boolean  @default(false) @map("email_promotions")
  emailNews             Boolean  @default(false) @map("email_news")
  emailBlogDigest       Boolean  @default(false) @map("email_blog_digest")
  pushBrowser           Boolean  @default(false) @map("push_browser")
  soundNewMessages      Boolean  @default(false) @map("sound_new_messages")
  preferredLocale       String   @default("ru") @map("preferred_locale")
  autoTranslate         Boolean  @default(true) @map("auto_translate")
  autoTranslateExclude  String[] @default([]) @map("auto_translate_exclude")
  theme                 String   @default("light")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  projects Project[]
  skills   Skill[]
  minBudgets CategoryMinBudget[]

  @@map("categories")
}

model Skill {
  id         String   @id @default(cuid())
  name       String   @unique
  slug       String   @unique
  categoryId String?  @map("category_id")
  createdAt  DateTime @default(now()) @map("created_at")

  category    Category?           @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  freelancers FreelancerProfile[] @relation("FreelancerSkills")

  @@index([categoryId])
  @@map("skills")
}

model Project {
  id            String        @id @default(cuid())
  slug          String        @unique
  clientId      String        @map("client_id")
  categoryId    String?       @map("category_id")
  title         String
  description   String        @db.Text
  budget        Decimal?      @db.Decimal(12, 2)
  currency      String        @default("UAH")
  status        ProjectStatus @default(OPEN)
  deadline      DateTime?
  viewsCount    Int           @default(0) @map("views_count")
  isFeatured    Boolean       @default(false) @map("is_featured")
  featuredUntil DateTime?     @map("featured_until")
  reportCount            Int           @default(0) @map("report_count")
  underpricedReportCount Int           @default(0) @map("underpriced_report_count")
  moderationHot          Boolean       @default(false) @map("moderation_hot")
  hiddenFromCatalog      Boolean       @default(false) @map("hidden_from_catalog")
  blockedAt              DateTime?     @map("blocked_at")
  blockReason            String?       @map("block_reason") @db.Text
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  client       User          @relation("ClientProjects", fields: [clientId], references: [id], onDelete: Cascade)
  category     Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  bids         Bid[]
  contract     Contract?
  conversation Conversation?
  reports      Report[]

  @@index([status])
  @@index([categoryId])
  @@index([createdAt])
  @@index([isFeatured])
  @@map("projects")
}

model Bid {
  id           String    @id @default(cuid())
  projectId    String    @map("project_id")
  freelancerId String    @map("freelancer_id")
  cost         Decimal   @db.Decimal(12, 2)
  timeframe    Int
  coverLetter  String    @map("cover_letter") @db.Text
  status       BidStatus @default(PENDING)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  project    Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  freelancer User         @relation(fields: [freelancerId], references: [id], onDelete: Cascade)
  messages   BidMessage[]

  @@unique([projectId, freelancerId])
  @@index([status])
  @@map("bids")
}

model BidMessage {
  id              String      @id @default(cuid())
  bidId           String      @map("bid_id")
  senderId        String?     @map("sender_id")
  kind            MessageKind @default(USER)
  violationUserId String?     @map("violation_user_id")
  blockedSnippet  String?     @map("blocked_snippet") @db.Text
  content         String      @db.Text
  createdAt       DateTime    @default(now()) @map("created_at")

  bid           Bid   @relation(fields: [bidId], references: [id], onDelete: Cascade)
  sender        User? @relation("BidMessagesSent", fields: [senderId], references: [id], onDelete: Cascade)
  violationUser User? @relation("BidMessageViolations", fields: [violationUserId], references: [id], onDelete: SetNull)

  @@index([bidId, createdAt])
  @@map("bid_messages")
}

model AdminContactWarningDismissal {
  id              String   @id @default(cuid())
  adminId         String   @map("admin_id")
  attentionItemId String   @map("attention_item_id")
  createdAt       DateTime @default(now()) @map("created_at")

  admin User @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@unique([adminId, attentionItemId])
  @@index([adminId])
  @@map("admin_contact_warning_dismissals")
}

model Contract {
  id             String         @id @default(cuid())
  projectId      String         @unique @map("project_id")
  clientId       String         @map("client_id")
  freelancerId   String         @map("freelancer_id")
  amount         Decimal        @db.Decimal(12, 2)
  commission     Decimal        @default(0) @db.Decimal(12, 2)
  freelancerPayout Decimal        @default(0) @map("freelancer_payout") @db.Decimal(12, 2)
  status         ContractStatus @default(ESCROWED)
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  client     User     @relation("ClientContracts", fields: [clientId], references: [id], onDelete: Cascade)
  freelancer User     @relation("FreelancerContracts", fields: [freelancerId], references: [id], onDelete: Cascade)
  reviews    Review[]

  @@map("contracts")
}

model Review {
  id         String   @id @default(cuid())
  contractId String   @map("contract_id")
  fromUserId String   @map("from_user_id")
  toUserId   String   @map("to_user_id")
  rating     Int
  text       String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  fromUser User     @relation("ReviewsGiven", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User     @relation("ReviewsReceived", fields: [toUserId], references: [id], onDelete: Cascade)

  @@unique([contractId, fromUserId])
  @@map("reviews")
}

model Conversation {
  id                    String    @id @default(cuid())
  projectId             String    @unique @map("project_id")
  clientId              String    @map("client_id")
  freelancerId          String    @map("freelancer_id")
  hiddenByClientAt      DateTime? @map("hidden_by_client_at")
  hiddenByFreelancerAt  DateTime? @map("hidden_by_freelancer_at")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  client     User      @relation("ClientConversations", fields: [clientId], references: [id], onDelete: Cascade)
  freelancer User      @relation("FreelancerConversations", fields: [freelancerId], references: [id], onDelete: Cascade)
  messages   Message[]

  @@map("conversations")
}

model Message {
  id              String      @id @default(cuid())
  conversationId  String      @map("conversation_id")
  senderId        String?     @map("sender_id")
  kind            MessageKind @default(USER)
  violationUserId String?     @map("violation_user_id")
  blockedSnippet  String?     @map("blocked_snippet") @db.Text
  content         String      @db.Text
  readAt          DateTime?   @map("read_at")
  createdAt       DateTime    @default(now()) @map("created_at")

  conversation  Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender        User?        @relation("MessagesSent", fields: [senderId], references: [id], onDelete: Cascade)
  violationUser User?        @relation("MessageViolations", fields: [violationUserId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
  @@index([kind, createdAt])
  @@map("messages")
}

model Payment {
  id                    String        @id @default(cuid())
  userId                String        @map("user_id")
  amount                Decimal       @db.Decimal(12, 2)
  currency              String        @default("UAH")
  type                  PaymentType
  status                PaymentStatus @default(PENDING)
  stripeSessionId       String?       @unique @map("stripe_session_id")
  stripePaymentIntentId String?       @map("stripe_payment_intent_id")
  metadata              Json?
  createdAt             DateTime      @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("payments")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model Report {
  id              String           @id @default(cuid())
  reporterId      String           @map("reporter_id")
  targetType      ReportTargetType @map("target_type")
  targetUserId    String?          @map("target_user_id")
  targetProjectId String?          @map("target_project_id")
  reason          ReportReason
  details         String?          @db.Text
  status          ReportStatus     @default(PENDING)
  adminNote       String?          @map("admin_note") @db.Text
  resolvedById    String?          @map("resolved_by_id")
  resolvedAt      DateTime?        @map("resolved_at")
  createdAt       DateTime         @default(now()) @map("created_at")

  reporter      User     @relation("ReportsFiled", fields: [reporterId], references: [id], onDelete: Cascade)
  targetUser    User?    @relation("ReportsAgainstUser", fields: [targetUserId], references: [id], onDelete: Cascade)
  targetProject Project? @relation(fields: [targetProjectId], references: [id], onDelete: Cascade)
  resolvedBy    User?    @relation("ReportsResolved", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@index([reporterId, targetProjectId])
  @@index([reporterId, targetUserId])
  @@index([status, createdAt])
  @@index([targetProjectId, status])
  @@index([targetUserId, status])
  @@map("reports")
}

model CategoryMinBudget {
  id         String   @id @default(cuid())
  categoryId String   @map("category_id")
  currency   String
  minAmount  Decimal  @map("min_amount") @db.Decimal(12, 2)
  createdAt  DateTime @default(now()) @map("created_at")

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, currency])
  @@map("category_min_budgets")
}
